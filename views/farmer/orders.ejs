<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Customer Orders - AgriTech</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand-lg navbar-dark bg-success mb-4">
    <div class="container">
      <a class="navbar-brand" href="/farmer/dashboard"><i class="fas fa-seedling me-2"></i>AgriTech Dashboard</a>
      <div class="ms-auto d-flex align-items-center text-white">
        <a href="/farmer/dashboard" class="text-white text-decoration-none me-3"><i class="fas fa-arrow-left me-1"></i> Back to Products</a>
      </div>
    </div>
  </nav>

  <div class="container">
    <h2 class="mb-4"><i class="fas fa-shopping-basket me-2"></i>Customer Orders</h2>
    <div class="card shadow-sm">
      <div class="card-body">
        <% if (orders.length === 0) { %>
          <div class="text-center py-5 text-muted">
            <i class="fas fa-inbox fa-3x mb-3"></i>
            <h5>No orders yet</h5>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table align-middle">
              <thead>
                <tr>
                  <th>Order Date</th>
                  <th>Product</th>
                  <th>Buyer Details</th>
                  <th>Qty (Total)</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% orders.forEach(order => { %>
                  <tr>
                    <td><%= new Date(order.createdAt).toLocaleDateString() %></td>
                    <td>
                      <div class="d-flex flex-column gap-2">
                        <% const items = order.items || [];
                           items.forEach(item => { const p = item.productId || {}; %>
                          <div class="d-flex align-items-center border-bottom pb-1">
                            <% if(p.image) { %>
                              <img src="<%= p.image %>" class="rounded me-2" style="width: 30px; height: 30px; object-fit: cover;">
                            <% } %>
                            <div>
                              <strong><%= p.name || 'Unknown' %></strong>
                              <br><small class="text-muted"><%= item.quantity %> <%= p.unit || 'units' %> x ₹<%= item.price %></small>
                            </div>
                          </div>
                        <% }) %>
                      </div>
                    </td>
                    <td>
                      <div><strong><%= order.buyerDetails.name %></strong></div>
                      <div><small class="text-muted"><i class="fas fa-phone me-1"></i><%= order.buyerDetails.phone %></small></div>
                      <div><small class="text-muted"><i class="fas fa-map-marker-alt me-1"></i><%= order.buyerDetails.address %></small></div>
                    </td>
                    <td>
                      <small class="text-success fw-bold fs-6">₹<%= order.totalPrice %></small>
                      <br><small class="text-muted">Payment: <%= order.paymentMethod %></small>
                    </td>
                    <td>
                      <% 
                         let statColor = 'secondary';
                         if(order.status === 'pending') statColor = 'warning';
                         if(order.status === 'accepted') statColor = 'info';
                         if(order.status === 'delivered') statColor = 'success';
                         if(order.status === 'rejected') statColor = 'danger';
                      %>
                      <span class="badge bg-<%= statColor %>"><%= order.status.toUpperCase() %></span>
                    </td>
                    <td>
                      <% if (order.status === 'pending') { %>
                        <form action="/farmer/orders/<%= order._id %>/status" method="POST" class="d-inline">
                          <input type="hidden" name="status" value="accepted">
                          <button type="submit" class="btn btn-sm btn-success p-1 px-2" title="Accept"><i class="fas fa-check"></i></button>
                        </form>
                        <form action="/farmer/orders/<%= order._id %>/status" method="POST" class="d-inline">
                          <input type="hidden" name="status" value="rejected">
                          <button type="submit" class="btn btn-sm btn-danger p-1 px-2" title="Reject"><i class="fas fa-times"></i></button>
                        </form>
                      <% } else if (order.status === 'accepted') { %>
                        <form action="/farmer/orders/<%= order._id %>/status" method="POST" class="d-inline">
                          <input type="hidden" name="status" value="delivered">
                          <button type="submit" class="btn btn-sm btn-outline-success p-1 px-2"><i class="fas fa-truck me-1"></i>Mark Delivered</button>
                        </form>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</body>
</html>
