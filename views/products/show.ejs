<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product.name %> - AgriTech Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/dashboard.css">
    <style>
        /* Additional styles for product detail page */
        .product-detail {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem 1.5rem;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            color: var(--gray-600);
            margin-bottom: 1.5rem;
            font-weight: 500;
            transition: color 0.2s ease;
        }

        .back-link:hover {
            color: var(--primary);
            text-decoration: none;
        }

        .back-link i {
            margin-right: 0.5rem;
            font-size: 1.25rem;
        }

        .product-detail__gallery {
            position: relative;
            overflow: hidden;
            border-radius: var(--radius-lg);
            background: var(--gray-50);
            box-shadow: var(--shadow);
        }

        .product-detail__image {
            width: 100%;
            height: 0;
            padding-bottom: 100%;
            position: relative;
            background: white;
        }

        .product-detail__image img {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: contain;
            padding: 2rem;
        }

        .product-detail__info {
            padding: 2rem;
            background: white;
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow);
            height: 100%;
        }

        .product-detail__header {
            margin-bottom: 1.5rem;
            padding-bottom: 1.5rem;
            border-bottom: 1px solid var(--gray-100);
        }

        .product-detail__title {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            color: var(--gray-900);
        }

        .product-detail__meta {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
        }

        .product-detail__price {
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--primary);
            margin: 0;
        }

        .product-detail__category {
            display: inline-flex;
            align-items: center;
            padding: 0.375rem 0.875rem;
            background: var(--primary-light);
            color: var(--primary);
            border-radius: 1.5rem;
            font-size: 0.875rem;
            font-weight: 600;
        }

        .product-detail__category i {
            margin-right: 0.5rem;
            font-size: 1rem;
        }

        .product-detail__id {
            font-size: 0.875rem;
            color: var(--gray-500);
            margin: 0.5rem 0;
            display: block;
        }

        .product-detail__section {
            margin-bottom: 1.5rem;
        }

        .product-detail__section-title {
            font-size: 1.125rem;
            font-weight: 600;
            margin-bottom: 0.75rem;
            color: var(--gray-900);
        }

        .product-detail__description {
            color: var(--gray-700);
            line-height: 1.7;
            margin-bottom: 1.5rem;
        }

        .product-detail__specs {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .spec-item {
            display: flex;
            flex-direction: column;
        }

        .spec-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--gray-500);
            margin-bottom: 0.25rem;
        }

        .spec-value {
            font-weight: 500;
            color: var(--gray-800);
        }

        .product-detail__actions {
            display: flex;
            gap: 1rem;
            margin-top: 2rem;
            padding-top: 1.5rem;
            border-top: 1px solid var(--gray-100);
        }

        /* Responsive styles */
        @media (min-width: 768px) {
            .product-detail {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 2rem;
                padding: 2rem 1.5rem;
            }

            .product-detail__gallery {
                position: sticky;
                top: 2rem;
            }
        }

        @media (max-width: 767px) {
            .product-detail__specs {
                grid-template-columns: 1fr;
            }

            .product-detail__actions {
                flex-direction: column;
            }

            .product-detail__actions .btn {
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <div class="dashboard">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar__header">
                <div class="logo">
                    <i class="fas fa-leaf"></i>
                    <span>AgriTech</span>
                </div>
            </div>
            
            <nav class="sidebar__nav">
                <a href="/products" class="nav-item">
                    <i class="fas fa-th-large"></i>
                    <span>Dashboard</span>
                </a>
                <a href="/products/new" class="nav-item">
                    <i class="fas fa-plus-circle"></i>
                    <span>Add Product</span>
                </a>
                <div class="nav-section">
                    <span class="nav-section__title">Categories</span>
                    <a href="/products?category=fruits" class="nav-item">
                        <i class="fas fa-apple-alt"></i>
                        <span>Fruits</span>
                    </a>
                    <a href="/products?category=vegetables" class="nav-item">
                        <i class="fas fa-carrot"></i>
                        <span>Vegetables</span>
                    </a>
                    <a href="/products?category=dairy" class="nav-item">
                        <i class="fas fa-cheese"></i>
                        <span>Dairy</span>
                    </a>
                    <a href="/products?category=grains" class="nav-item">
                        <i class="fas fa-wheat-awn"></i>
                        <span>Grains</span>
                    </a>
                    <a href="/products?category=spices" class="nav-item">
                        <i class="fas fa-mortar-pestle"></i>
                        <span>Spices</span>
                    </a>
                    <a href="/products?category=organic" class="nav-item">
                        <i class="fas fa-leaf"></i>
                        <span>Organic</span>
                    </a>
                </div>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Top Header -->
            <header class="top-header">
                <div class="header-left">
                    <button class="menu-toggle">
                        <i class="fas fa-bars"></i>
                    </button>
                    <a href="/products" class="back-link">
                        <i class="fas fa-arrow-left"></i>
                        Back to Products
                    </a>
                </div>
                <div class="header-actions">
                    <a href="/products/new" class="btn btn-primary">
                        <i class="fas fa-plus"></i>
                        <span>Add Product</span>
                    </a>
                </div>
            </header>

            <div class="product-detail">
                <a href="/products" class="back-link">
                    <i class="fas fa-arrow-left"></i>
                    Back to Products
                </a>

                <div class="product-detail__grid">
                    <div class="product-detail__gallery">
                        <div class="product-detail__image">
                            <img src="<%= product.image || '/images/placeholder-product.jpg' %>" alt="<%= product.name %>">
                        </div>
                    </div>
                    <div class="product-detail__info">
                        <div class="product-detail__header">
                            <h1 class="product-detail__title"><%= product.name %></h1>
                            <div class="product-detail__meta">
                                <div class="product-detail__price">₹<%= product.price.toFixed(2) %></div>
                                <span class="product-detail__category">
                                    <i class="fas fa-tag"></i>
                                    <%= product.category %>
                                </span>
                                <% if (product.isOrganic) { %>
                                    <span class="badge badge-primary">
                                        <i class="fas fa-leaf"></i> Organic
                                    </span>
                                <% } %>
                            </div>
                            <span class="product-detail__id">Product ID: <%= product._id %></span>
                        </div>

                        <div class="product-detail__section">
                            <h3 class="product-detail__section-title">Description</h3>
                            <p class="product-detail__description"><%= product.description || 'No description available.' %></p>
                        </div>

                        <div class="product-detail__section">
                            <h3 class="product-detail__section-title">Product Details</h3>
                            <div class="product-detail__specs">
                                <div class="spec-item">
                                    <span class="spec-label">Quantity</span>
                                    <span class="spec-value"><%= product.quantity %></span>
                                </div>
                                <div class="spec-item">
                                    <span class="spec-label">Category</span>
                                    <span class="spec-value"><%= product.category %></span>
                                </div>
                                <div class="spec-item">
                                    <span class="spec-label">Status</span>
                                    <span class="spec-value"><%= product.quantity > 0 ? 'In Stock' : 'Out of Stock' %></span>
                                </div>
                                <div class="spec-item">
                                    <span class="spec-label">Added On</span>
                                    <span class="spec-value"><%= new Date(product.createdAt).toLocaleDateString() %></span>
                                </div>
                            </div>
                        </div>

                        <div class="product-detail__actions">
                            <a href="/products/<%= product._id %>/edit" class="btn btn-primary">
                                <i class="fas fa-edit"></i>
                                Edit Product
                            </a>
                            <form action="/products/<%= product._id %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this product?')">
                                <button type="submit" class="btn btn-danger">
                                    <i class="fas fa-trash"></i>
                                    Delete Product
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </main>

    <style>
        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            color: var(--gray-600);
            text-decoration: none;
            font-weight: 500;
            margin-bottom: 1rem;
            transition: var(--transition);
        }

        .back-link:hover {
            color: var(--primary-color);
        }

        .product-detail {
            background: var(--white);
            border-radius: var(--border-radius-xl);
            box-shadow: var(--shadow);
            overflow: hidden;
            display: grid;
            grid-template-columns: 1fr 1fr;
            min-height: 500px;
        }

        .product-detail__image {
            position: relative;
            background: var(--gray-100);
        }

        .product-detail__image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .product-detail__content {
            padding: 3rem;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .product-detail__header {
            margin-bottom: 2rem;
        }

        .product-detail__title {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--gray-900);
            margin-bottom: 1rem;
        }

        .product-detail__price {
            font-size: 3rem;
            font-weight: 800;
            color: var(--primary-color);
        }

        .product-detail__meta {
            margin-bottom: 2rem;
        }

        .meta-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 0;
            border-bottom: 1px solid var(--gray-200);
        }

        .meta-item:last-child {
            border-bottom: none;
        }

        .meta-label {
            font-weight: 600;
            color: var(--gray-700);
        }

        .meta-value {
            color: var(--gray-600);
            font-family: monospace;
            font-size: 0.875rem;
        }

        .product-detail__actions {
            display: flex;
            gap: 1rem;
        }

        .btn--danger {
            background: var(--danger-color);
            color: var(--white);
        }

        .btn--danger:hover {
            background: #dc2626;
        }

        @media (max-width: 768px) {
            .product-detail {
                grid-template-columns: 1fr;
            }
            
            .product-detail__content {
                padding: 2rem;
            }
            
            .product-detail__title {
                font-size: 2rem;
            }
            
            .product-detail__price {
                font-size: 2.5rem;
            }
            
            .product-detail__actions {
                flex-direction: column;
            }
        }
    </style>
</body>
</html>
